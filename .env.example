# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé secrète (service role) — SERVER ONLY, jamais exposée au client
SUPABASE_SECRET_KEY=
# Mot de passe Postgres — uniquement pour scripts/db-migrate.mjs (pas nécessaire sur Vercel)
SUPABASE_DB_PASSWORD=

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# Garde mono-utilisateur : seul cet email peut utiliser l'app
ALLOWED_EMAIL=
